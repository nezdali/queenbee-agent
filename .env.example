# --- Required ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
OPENAI_API_KEY=

# --- Optional ---------------------------------------------------------------

# LLM defaults
LLM_MODEL=gpt-4o-mini
CODEX_MODEL=gpt-4o-mini
HISTORY_DEPTH=20

# System prompt prepended to every conversation
# SYSTEM_PROMPT=You are a helpful, friendly AI assistant inside a Telegram chat.

# Telegram user ID of the bot admin. Unset/0 disables all admin commands.
QB_ADMIN_USER_ID=

# Access control (comma-separated). Leave empty for no restriction.
# ALLOWED_USERS=123456789,987654321
# ALLOWED_USERNAMES=alice,bob

# Static user -> roles mapping (in addition to /adduser persistent store)
# Format: "uid1:role1,role2;uid2:role3"
# USER_ROLES=

# Optional: SerpAPI key for Google Shopping / Search inside generated tools
# SERPAPI_KEY=

# Optional: hydrate the secrets above from Azure Key Vault
# AZURE_KEYVAULT_URL=https://your-vault-name.vault.azure.net/

# ---------------------------------------------------------------------------
# Optional third-party integrations
# Each block is independent; leave blank to disable.
# See README "Optional Integrations" for full setup steps.
# ---------------------------------------------------------------------------

# --- Strava (fitness, OAuth) ---
# Create an app: https://www.strava.com/settings/api  (callback domain: localhost)
# STRAVA_CLIENT_ID=
# STRAVA_CLIENT_SECRET=
# Where per-user token JSON files (strava_token_<uid>.json) are written.
# STRAVA_TOKEN_DIR=.

# --- Spotify (music, OAuth) ---
# Create an app: https://developer.spotify.com/dashboard
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
# SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# --- eWeLink (Sonoff / iTead smart home) ---
# EWELINK_EMAIL=
# EWELINK_PASSWORD=
# EWELINK_PHONE=
# EWELINK_REGION=eu   # us | eu | as | cn

# --- Huum sauna controller ---
# HUUM_USERNAME=
# HUUM_PASSWORD=

# --- Atlantic / Cozytouch heat pump ---
# COZYTOUCH_USERNAME=
# COZYTOUCH_PASSWORD=

# --- TMDB (used by movie_search tool) ---
# Free API key at https://www.themoviedb.org/settings/api
# TMDB_API_KEY=

# --- OpenAI Admin API key (used by openai_api_usage_status tool) ---
# Separate org-level key; see https://platform.openai.com/settings/organization/admin-keys
# OPENAI_ADMIN_API_KEY=

# --- ElevenLabs TTS (optional, used by media_creator tool) ---
# ELEVENLABS_API_KEY=

# --- Yandex translation (optional) ---
# YANDEX_API_KEY=

# --- KNOWN_USERS: alias -> Telegram user_id (cross-user lookups) ---
# Allows tools (e.g. Strava) to resolve names like "Alice" to user_ids.
# Format: "alias1:uid1;alias2:uid2"  (multiple aliases may share a uid)
# KNOWN_USERS=alice:123456789;al:123456789;bob:987654321
